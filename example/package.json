{
  "name": "expo-downloads-example",
  "license": "0BSD",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "pnpm run /^lint:/",
    "lint:eslint": "eslint \"*.{js,ts,tsx}\"",
    "lint:prettier": "prettier --check \"*.{js,ts,tsx}\"",
    "fix": "pnpm run /^fix:/",
    "fix:eslint": "eslint --fix \"*.{js,ts,tsx}\"",
    "fix:prettier": "prettier --write \"*.{js,ts,tsx}\""
  },
  "dependencies": {
    "@expo/dom-webview": "~56.0.5",
    "expo": "~56.0.12",
    "expo-splash-screen": "~56.0.10",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-is": "^19.2.3",
    "react-native": "0.85.3",
    "react-native-web": "~0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.17",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^56.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.8.4",
    "typescript": "~6.0.3"
  },
  "private": true,
  "expo": {
    "autolinking": {
      "nativeModulesDir": ".."
    },
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      }
    }
  },
  "packageManager": "pnpm@11.7.0"
}
