{
  "name": "expo-downloads-example",
  "license": "0BSD",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "pnpm run /^lint:/",
    "lint:eslint": "eslint \"*.{js,ts,tsx}\"",
    "lint:prettier": "prettier --check \"*.{js,ts,tsx}\"",
    "fix": "pnpm run /^fix:/",
    "fix:eslint": "eslint --fix \"*.{js,ts,tsx}\"",
    "fix:prettier": "prettier --write \"*.{js,ts,tsx}\""
  },
  "dependencies": {
    "expo": "~55.0.5",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-is": "^19.2.0",
    "react-native": "0.83.2",
    "react-native-web": "~0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "private": true,
  "expo": {
    "autolinking": {
      "nativeModulesDir": ".."
    }
  },
  "packageManager": "pnpm@10.32.1"
}
